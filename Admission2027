<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script type="text/javascript">
    (function() {
        emailjs.init("CeIzWuZvq5eRchl18"); // Public Key
    })();

    document.getElementById('admissionForm').addEventListener('submit', function(event) {
        event.preventDefault();

        const btn = document.getElementById('submitBtn');
        btn.innerHTML = 'প্রসেস হচ্ছে...';
        btn.disabled = true;

        // সুনির্দিষ্ট আইডি (IDs) দিয়ে সঠিক ভ্যালু ক্যাচ করা হয়েছে
        const params = {
            student_name: document.getElementById('student_name_bn').value,
            student_class: document.getElementById('office_class').value, // সঠিক অফিস ড্রপডাউন ডেটা
            phone: document.getElementById('father_phone').value,
        };

        emailjs.send("service_kalaya", "template_2ra5c35", params)
            .then(function() {
                Swal.fire({
                    title: 'সফল হয়েছে!',
                    text: 'আবেদনটি ওল্ড ডেটার সাথে মার্জ করে সফলভাবে সাবমিট করা হয়েছে।',
                    icon: 'success',
                    confirmButtonColor: '#006A4E'
                });
                document.getElementById('admissionForm').reset();
                btn.innerHTML = 'আবেদন সম্পন্ন করুন';
                btn.disabled = false;
            }, function(error) {
                Swal.fire({
                    title: 'ভুল হয়েছে!',
                    text: 'দুঃখিত, কোনো একটি ইন্টারনাল সমস্যার কারণে পাঠানো যায়নি।',
                    icon: 'error'
                });
                btn.innerHTML = 'আবেদন সম্পন্ন করুন';
                btn.disabled = false;
            });
    });
</script>

