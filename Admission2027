<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ভর্তি আবেদন - কালাইয়া বোর্ড সরকারি প্রাথমিক বিদ্যালয়</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap');
        
        body { font-family: 'Hind Siliguri', sans-serif; background-color: #f0fdf4; color: #333; }
        .form-container { background: #fff; border-radius: 30px; box-shadow: 0 20px 50px rgba(0,0,0,0.1); padding: 40px; margin-top: 50px; margin-bottom: 50px; border-top: 8px solid #006A4E; }
        .form-header { text-align: center; margin-bottom: 40px; position: relative; }
        .form-header h2 { color: #006A4E; font-weight: 700; }
        .section-title { background: #e8f5e9; color: #006A4E; padding: 10px 20px; border-radius: 10px; font-weight: 600; margin-top: 35px; margin-bottom: 20px; border-left: 5px solid #FFB800; }
        .form-label { font-weight: 600; color: #444; margin-bottom: 5px; }
        .form-control, .form-select { border-radius: 12px; padding: 12px; border: 1px solid #ddd; transition: 0.3s; }
        .form-control:focus, .form-select:focus { border-color: #006A4E; box-shadow: 0 0 0 0.25rem rgba(0, 106, 78, 0.1); }
        
        /* টেবিল স্টাইল */
        .table-custom { width: 100%; border-collapse: collapse; margin-top: 10px; border-radius: 12px; overflow: hidden; }
        .table-custom th { background-color: #006A4E; color: white; padding: 12px; border: 1px solid #006A4E; text-align: center; }
        .table-custom td { padding: 12px; border: 1px solid #dee2e6; vertical-align: middle; text-align: center; }
        
        .photo-box { border: 2px dashed #006A4E; width: 150px; height: 180px; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 15px; margin: 0 auto; background: #fafafa; color: #666; font-size: 14px; text-align: center; padding: 10px; }
        .btn-submit { background: #006A4E; color: white; padding: 15px 40px; border-radius: 50px; font-weight: 700; border: none; width: 100%; font-size: 18px; transition: 0.4s; }
        .btn-submit:hover { background: #004d39; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.15); }
        .office-use { background-color: #fffde7; border: 2px dashed #FFB800; border-radius: 20px; padding: 25px; margin-bottom: 30px; }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="form-container">
                
                <div class="form-header row align-items-center">
                    <div class="col-md-2 text-center text-md-start">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/6/67/Kalaya_Board_School_Logo.png" width="150" alt="School Logo" class="mb-3">
                    </div>
                    <div class="col-md-8 text-center">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/8/84/Government_Seal_of_Bangladesh.svg" width="60" alt="Govt Logo" class="mb-3">
                        <h6>গণপ্রজাতন্ত্রী বাংলাদেশ সরকার</h6>
                        <h6>সরকারি প্রাথমিক বিদ্যালয়ের ভর্তি ফরম (অভিন্ন)</h6>
                        <h2>কালাইয়া বোর্ড সরকারি প্রাথমিক বিদ্যালয়</h2>
                        <h5 class="text-muted mb-1">জিয়ানগর, পিরোজপুর | স্থাপিত: ১৯৩০ খ্রি.</h5>
                        <p class="small text-secondary">ইএমআইএস কোড- ৯১৫০২০৩১০০১  |  বিদ্যালয় কোড: ১৪৩১০১</p>
                    </div>
                    <div class="col-md-2 text-center">
                        <div class="photo-box mb-3">
                            <div><i class="fas fa-user-plus me-1"></i> শিক্ষার্থীর ছবি</div>
                            <input type="file" id="student_photo" class="form-control mt-2 form-control-sm" accept="image/*" required>
                        </div>
                    </div>
                </div>

                <form id="admissionForm">

                    <!-- ৭. অফিস কর্তৃক পূরণীয় -->
                    <div class="office-use">
                        <div class="fw-bold text-danger mb-3"><i class="fas fa-laptop-house me-2"></i> ৭. অফিস কর্তৃক পূরণীয় (For Office Use Only)</div>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">ভর্তি নম্বর</label>
                                <input type="text" id="office_admission_no" class="form-control" placeholder="অফিস পূরণ করবে">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">ভর্তির তারিখ</label>
                                <input type="date" id="office_admission_date" class="form-control">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">ভর্তিকৃত শ্রেণি</label>
                                <select id="office_class" class="form-select">
                                    <option value="">নির্বাচন করুন</option>
                                    <option>প্রাক-প্রাথমিক ৪+</option>
                                    <option>প্রাক-প্রাথমিক ৫+</option>
                                    <option>প্রথম শ্রেণি</option>
                                    <option selected>দ্বিতীয় শ্রেণি</option>
                                    <option>তৃতীয় শ্রেণি</option>
                                    <option>চতুর্থ শ্রেণি</option>
                                    <option>পঞ্চম শ্রেণি</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">শিক্ষাবর্ষ</label>
                                <select id="office_year" class="form-select">
                                    <option>২০২৩</option>
                                    <option>২০২৪</option>
                                    <option>২০২৫</option>
                                    <option>২০২৬</option>
                                    <option selected>২০২৭</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">শ্রেণি রোল</label>
                                <input type="text" id="office_roll" class="form-control" placeholder="রোল নম্বর">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">শাখা</label>
                                <input type="text" id="office_section" class="form-control" placeholder="যেমন: ক, খ বা প্রযোজ্য নয়">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">দায়িত্বপ্রাপ্ত শিক্ষকের স্বাক্ষর আপলোড</label>
                                <input type="file" id="office_signature" class="form-control" accept="image/*,.pdf">
                            </div>
                        </div>
                    </div>

                    <!-- ১. সাধারণ তথ্য -->
                    <div class="section-title"><i class="fas fa-id-card me-2"></i> ১. সাধারণ তথ্য (General Information)</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">শিক্ষার্থীর নাম (বাংলায়)</label>
                            <input type="text" id="student_name_bn" class="form-control" required placeholder="উদাঃ আবদুর রহমান">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">শিক্ষার্থীর নাম (ইংরেজিতে বড় অক্ষরে)</label>
                            <input type="text" id="student_name_en" class="form-control" required placeholder="Ex: ABDUR RAHMAN">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">জন্ম নিবন্ধন নম্বর</label>
                            <input type="text" id="birth_reg_no" class="form-control" required placeholder="১৭ ডিজিটের নম্বর">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">জন্ম তারিখ</label>
                            <input type="date" id="birth_date" class="form-control" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">বয়স (ভর্তিকালীন)</label>
                            <div class="input-group">
                                <input type="number" id="age_years" class="form-control" placeholder="বছর">
                                <input type="number" id="age_months" class="form-control" placeholder="মাস">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">লিঙ্গ</label>
                            <div class="d-flex gap-3 pt-2">
                                <div class="form-check"><input class="form-check-input" type="radio" name="gender" id="g1" value="ছেলে" required><label class="form-check-label" for="g1">ছেলে</label></div>
                                <div class="form-check"><input class="form-check-input" type="radio" name="gender" id="g2" value="মেয়ে"><label class="form-check-label" for="g2">মেয়ে</label></div>
                                <div class="form-check"><input class="form-check-input" type="radio" name="gender" id="g3" value="অন্যান্য"><label class="form-check-label" for="g3">অন্যান্য</label></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ধর্ম</label>
                            <input type="text" id="religion" class="form-control" placeholder="উদাঃ ইসলাম, হিন্দু">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">জাতীয়তা</label>
                            <input type="text" id="nationality" class="form-control" value="বাংলাদেশী">
                        </div>
                    </div>

                    <!-- ২. পারিবারিক তথ্য -->
                    <div class="section-title"><i class="fas fa-users me-2"></i> ২. পারিবারিক তথ্য (Family Information)</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="p-3 border rounded-3 bg-light">
                                <h6 class="fw-bold text-success mb-3"><i class="fas fa-user-tie me-2"></i> পিতার বিবরণ</h6>
                                <div class="mb-2"><label class="form-label">পিতার নাম (বাংলা)</label><input type="text" id="father_name_bn" class="form-control" required></div>
                                <div class="mb-2"><label class="form-label">পিতার নাম (ইংরেজি)</label><input type="text" id="father_name_en" class="form-control"></div>
                                <div class="mb-2"><label class="form-label">পিতার এনআইডি (NID) নম্বর</label><input type="text" id="father_nid" class="form-control" required></div>
                                <div class="mb-2"><label class="form-label">জন্ম তারিখ</label><input type="date" id="father_dob" class="form-control"></div>
                                <div class="mb-2"><label class="form-label">মোবাইল নম্বর</label><input type="tel" id="father_phone" class="form-control" placeholder="01XXXXXXXXX" required></div>
                                <div><label class="form-label">পেশা</label><input type="text" id="father_job" class="form-control"></div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 border rounded-3 bg-light">
                                <h6 class="fw-bold text-success mb-3"><i class="fas fa-user me-2"></i> মাতার বিবরণ</h6>
                                <div class="mb-2"><label class="form-label">মাতার নাম (বাংলা)</label><input type="text" id="mother_name_bn" class="form-control" required></div>
                                <div class="mb-2"><label class="form-label">মাতার নাম (ইংরেজি)</label><input type="text" id="mother_name_en" class="form-control"></div>
                                <div class="mb-2"><label class="form-label">মাতার এনআইডি (NID) নম্বর</label><input type="text" id="mother_nid" class="form-control" required></div>
                                <div class="mb-2"><label class="form-label">জন্ম তারিখ</label><input type="date" id="mother_dob" class="form-control"></div>
                                <div class="mb-2"><label class="form-label">মোবাইল নম্বর</label><input type="tel" id="mother_phone" class="form-control" placeholder="01XXXXXXXXX" required></div>
                                <div><label class="form-label">পেশা</label><input type="text" id="mother_job" class="form-control"></div>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="p-3 border rounded-3 bg-light">
                                <h6 class="fw-bold text-success mb-3"><i class="fas fa-user-shield me-2"></i> অভিভাবকের বিবরণ (পিতা-মাতার অবর্তমানে)</h6>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label">অভিভাবকের নাম</label>
                                        <input type="text" id="guardian_name" class="form-control" placeholder="প্রযোজ্য ক্ষেত্রে">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">অভিভাবকের এনআইডি (NID) নম্বর</label>
                                        <input type="text" id="guardian_nid" class="form-control" placeholder="এনআইডি নম্বর">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">অভিভাবকের মোবাইল নম্বর</label>
                                        <input type="tel" id="guardian_phone" class="form-control" placeholder="01XXXXXXXXX">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">ভাইবোনের সংখ্যা (যদি একই বিদ্যালয়ে পড়ে বিস্তারিত)</label>
                            <input type="text" id="siblings_info" class="form-control" placeholder="যেমন: ০ জন / ১ জন (৩য় শ্রেণি, রোল ৫)">
                        </div>
                    </div>

                    <!-- ঠিকানা সেকশন -->
                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <div class="p-3 border rounded-3 bg-light h-100">
                                <h6 class="fw-bold mb-3 text-secondary"><i class="fas fa-map-marker-alt me-2"></i> স্থায়ী ঠিকানা</h6>
                                <div class="row g-2">
                                    <div class="col-6"><input type="text" id="p_village" class="form-control" placeholder="গ্রাম" required></div>
                                    <div class="col-6"><input type="text" id="p_home" class="form-control" placeholder="বাড়ি" required></div>
                                    <div class="col-4"><input type="text" id="p_post" class="form-control" placeholder="পোস্ট" required></div>
                                    <div class="col-4"><input type="text" id="p_sub" class="form-control" placeholder="উপজেলা" required></div>
                                    <div class="col-4"><input type="text" id="p_dist" class="form-control" placeholder="জেলা" required></div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 border rounded-3 bg-light h-100">
                                <h6 class="fw-bold mb-3 text-secondary"><i class="fas fa-route me-2"></i> বর্তমান ঠিকানা</h6>
                                <div class="row g-2">
                                    <div class="col-6"><input type="text" id="c_village" class="form-control" placeholder="গ্রাম" required></div>
                                    <div class="col-6"><input type="text" id="c_home" class="form-control" placeholder="বাড়ি" required></div>
                                    <div class="col-4"><input type="text" id="c_post" class="form-control" placeholder="পোস্ট" required></div>
                                    <div class="col-4"><input type="text" id="c_sub" class="form-control" placeholder="উপজেলা" required></div>
                                    <div class="col-4"><input type="text" id="c_dist" class="form-control" placeholder="জেলা" required></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ৩. শিক্ষাগত তথ্য -->
                    <div class="section-title"><i class="fas fa-graduation-cap me-2"></i> ৩. শিক্ষাগত তথ্য (Educational Background)</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">পূর্ববর্তী বিদ্যালয়ের নাম (যদি থাকে)</label>
                            <input type="text" id="prev_school" class="form-control" placeholder="বিদ্যালয়ের নাম লিখুন">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">শ্রেণি</label>
                            <input type="text" id="prev_class" class="form-control" placeholder="যেমন: প্রথম শ্রেণি">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">পূর্ববর্তী শ্রেণির ফলাফল</label>
                            <input type="text" id="prev_result" class="form-control" placeholder="যেমন: সন্তোষজনক/উত্তীর্ণ">
                        </div>
                    </div>

                    <!-- ৪. স্বাস্থ্য সংক্রান্ত তথ্য -->
                    <div class="section-title"><i class="fas fa-heartbeat me-2"></i> ৪. স্বাস্থ্য সংক্রান্ত তথ্য (Health Information)</div>
                    
                    <h6><strong>(ক) মৌলিক স্বাস্থ্য তথ্য:</strong></h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">রক্তের গ্রুপ</label>
                            <select id="blood_group" class="form-select">
                                <option value="">নির্বাচন করুন</option>
                                <option>A+</option><option>A-</option>
                                <option>B+</option><option>B-</option>
                                <option>AB+</option><option>AB-</option>
                                <option>O+</option><option>O-</option>
                                <option>জানা নেই</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">উচ্চতা (সে.মি.)</label>
                            <input type="text" id="height" class="form-control" placeholder="সেমি">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ওজন (কেজি)</label>
                            <input type="text" id="weight" class="form-control" placeholder="কেজি">
                        </div>
                    </div>

                    <!-- জরুরি যোগাযোগ -->
                    <div class="section-title"><i class="fas fa-phone-volume me-2"></i> ৫. জরুরি যোগাযোগ (Emergency Contact)</div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">জরুরি যোগাযোগের নাম</label>
                            <input type="text" id="emergency_name" class="form-control" required placeholder="যোগাযোগের ব্যক্তির নাম">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">সম্পর্ক</label>
                            <input type="text" id="emergency_relation" class="form-control" required placeholder="উদাঃ পিতা, মামা">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">মোবাইল নম্বর</label>
                            <input type="tel" id="emergency_phone" class="form-control" required placeholder="01XXXXXXXXX">
                        </div>
                    </div>

                    <!-- প্রয়োজনীয় কাগজপত্র সংযুক্তি -->
                    <div class="section-title"><i class="fas fa-paperclip me-2"></i> প্রয়োজনীয় কাগজপত্র আপলোড (সংযুক্তি)</div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">শিক্ষার্থীর অনলাইন জন্ম নিবন্ধন কপি</label>
                            <input type="file" id="doc_birth" class="form-control" accept="image/*,.pdf" required>
                        </div>
                        <div class="col-md-4">
